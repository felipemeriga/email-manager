{
	"info": {
		"_postman_id": "email-manager-api-v2",
		"name": "Email Manager API",
		"description": "REST API for managing Gmail emails via IMAP with intelligent importance scoring. Supports personal Gmail accounts using App Passwords.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Check if the API service is healthy and running"
					},
					"response": []
				}
			]
		},
		{
			"name": "Emails - Read Operations",
			"item": [
				{
					"name": "Get Recent Emails",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{api_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/emails/recent?limit=50",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"recent"
							],
							"query": [
								{
									"key": "limit",
									"value": "50",
									"description": "Maximum number of emails to retrieve (default: 50)"
								}
							]
						},
						"description": "Retrieve the most recent emails from your Gmail inbox"
					},
					"response": []
				},
				{
					"name": "Get Today's Emails",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/today?min_score=2",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"today"
							],
							"query": [
								{
									"key": "min_score",
									"value": "2",
									"description": "Minimum importance score (1-3) to filter emails"
								}
							]
						},
						"description": "Get all emails from today, optionally filtered by importance score"
					},
					"response": []
				},
				{
					"name": "Get Emails by Date",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/by-date/2024-02-27?min_score=1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"by-date",
								"2024-02-27"
							],
							"query": [
								{
									"key": "min_score",
									"value": "1",
									"description": "Minimum importance score (1-3) to filter emails"
								}
							]
						},
						"description": "Get emails from a specific date (YYYY-MM-DD format)"
					},
					"response": []
				}
			]
		},
		{
			"name": "Emails - Search",
			"item": [
				{
					"name": "Search Emails",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{api_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"from:example@gmail.com\",\n    \"min_score\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/emails/search",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"search"
							]
						},
						"description": "Search emails using Gmail query syntax with optional importance score filtering"
					},
					"response": []
				}
			]
		},
		{
			"name": "Emails - Status Management",
			"item": [
				{
					"name": "Mark Email as Read",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/{{email_id}}/read",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"{{email_id}}",
								"read"
							]
						},
						"description": "Mark a specific email as read by its ID"
					},
					"response": []
				},
				{
					"name": "Mark Email as Unread",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/{{email_id}}/unread",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"{{email_id}}",
								"unread"
							]
						},
						"description": "Mark a specific email as unread by its ID"
					},
					"response": []
				},
				{
					"name": "Bulk Mark as Read",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/bulk-mark-read?count=50",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"bulk-mark-read"
							],
							"query": [
								{
									"key": "count",
									"value": "50",
									"description": "Number of emails to mark as read (default: 50, max: 500)"
								}
							]
						},
						"description": "Mark multiple recent unread emails as read at once. Marks the most recent unread emails up to the specified count."
					},
					"response": []
				}
			]
		},
		{
			"name": "Emails - Delete Operations",
			"item": [
				{
					"name": "Delete Single Email",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/emails/{{email_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"{{email_id}}"
							]
						},
						"description": "Move a single email to trash by its ID"
					},
					"response": []
				},
				{
					"name": "Bulk Delete Emails",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"ids\": [\n        \"email_id_1\",\n        \"email_id_2\",\n        \"email_id_3\"\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/emails/bulk-delete",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"emails",
								"bulk-delete"
							]
						},
						"description": "Delete multiple emails at once by providing an array of email IDs"
					},
					"response": []
				}
			]
		},
		{
			"name": "MFA Code Extraction",
			"item": [
				{
					"name": "Get MFA Codes",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{api_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/mfa/codes?minutes=5&limit=20",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mfa",
								"codes"
							],
							"query": [
								{
									"key": "minutes",
									"value": "5",
									"description": "Time window in minutes to search for codes (default: 5)"
								},
								{
									"key": "limit",
									"value": "20",
									"description": "Maximum number of codes to return (default: 20)"
								},
								{
									"key": "service",
									"value": "Google",
									"description": "Optional: Filter by service name (e.g., Google, GitHub, Microsoft)",
									"disabled": true
								}
							]
						},
						"description": "Extract MFA/2FA verification codes from recent emails. The API searches through your recent emails looking for verification codes from services like Google, GitHub, Microsoft, AWS, etc.\n\n**How it works:**\n1. Scans emails from the last X minutes (configurable)\n2. Looks for verification keywords (code, verification, OTP, 2FA, etc.)\n3. Extracts numeric codes (4-6 digits) or alphanumeric codes\n4. Identifies the service from the sender's email address\n5. Returns structured data with the code and metadata\n\n**Supported Services:**\n- Google/Gmail\n- Microsoft/Outlook\n- GitHub\n- AWS\n- Facebook/Meta\n- Twitter/X\n- LinkedIn\n- Apple\n- PayPal\n- Discord\n- Slack\n- And many more...\n\n**Response includes:**\n- The verification code\n- Service name (auto-detected)\n- Email metadata (sender, subject, date)\n- Code type (numeric/alphanumeric)"
					},
					"response": []
				},
				{
					"name": "Get Latest MFA Code",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{api_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/mfa/latest?minutes=5",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mfa",
								"latest"
							],
							"query": [
								{
									"key": "minutes",
									"value": "5",
									"description": "Time window in minutes to search for codes (default: 5)"
								},
								{
									"key": "service",
									"value": "GitHub",
									"description": "Optional: Filter by specific service",
									"disabled": true
								}
							]
						},
						"description": "Get the most recent MFA/2FA code from your emails. Returns only the latest verification code found.\n\n**Use cases:**\n- Automated login scripts\n- Quick retrieval of the latest code\n- Service-specific code retrieval\n\n**Example Response:**\n```json\n{\n  \"code\": \"123456\",\n  \"service\": \"Google\",\n  \"email_id\": \"msg-12345\",\n  \"email_subject\": \"Sign in to Google\",\n  \"email_sender\": \"noreply@google.com\",\n  \"email_date\": \"2024-03-15T10:30:00Z\",\n  \"code_type\": \"numeric\"\n}\n```"
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{api_token}}",
				"type": "string"
			}
		]
	},
